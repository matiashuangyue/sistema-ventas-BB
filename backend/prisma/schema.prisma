generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String
  username  String   @unique
  password  String
  rol       String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Cliente {
  id            Int      @id @default(autoincrement())
  nombre        String
  telefono      String?
  direccion     String?
  localidad     String?
  cuit          String?
  observaciones String?
  createdAt     DateTime @default(now())

  ventas Venta[]
}

model Producto {
  id        Int      @id @default(autoincrement())
  nombre    String
  categoria String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  variantes Variante[]
}

model Variante {
  id          Int      @id @default(autoincrement())
  nombre      String
  stock       Int      @default(0)
  stockMinimo Int?
  productoId  Int
  createdAt   DateTime @default(now())

  producto Producto @relation(fields: [productoId], references: [id])
  precios  PrecioVariante[]
  detalles VentaDetalle[]
  compras CompraDetalle[]
}

model ListaPrecio {
  id     Int     @id @default(autoincrement())
  nombre String
  activa Boolean @default(true)

  precios PrecioVariante[]
}

model PrecioVariante {
  id            Int     @id @default(autoincrement())
  precio        Float
  varianteId    Int
  listaPrecioId Int

  variante    Variante    @relation(fields: [varianteId], references: [id])
  listaPrecio ListaPrecio @relation(fields: [listaPrecioId], references: [id])
}

model Venta {
  id        Int      @id @default(autoincrement())
  clienteId Int?
  fecha     DateTime @default(now())
  subtotal  Float
  descuento Float
  total     Float
  createdAt DateTime @default(now())

  cliente Cliente? @relation(fields: [clienteId], references: [id])
  detalles VentaDetalle[]
}

model VentaDetalle {
  id             Int     @id @default(autoincrement())
  ventaId        Int
  varianteId     Int
  cantidad       Int
  precioUnitario Float
  descuentoItem  Float?
  subtotal       Float

  venta    Venta    @relation(fields: [ventaId], references: [id])
  variante Variante @relation(fields: [varianteId], references: [id])
}

model Compra {
  id            Int             @id @default(autoincrement())
  proveedor     String?
  fecha         DateTime        @default(now())
  total         Float
  observaciones String?
  createdAt     DateTime        @default(now())

  detalles CompraDetalle[]
}

model CompraDetalle {
  id            Int      @id @default(autoincrement())
  compraId      Int
  varianteId    Int
  cantidad      Int
  costoUnitario Float
  subtotal      Float

  compra   Compra   @relation(fields: [compraId], references: [id])
  variante Variante @relation(fields: [varianteId], references: [id])
}